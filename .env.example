# ─────────────────────────────────────────────────────────────
# Database (MongoDB) — Prisma requires a REPLICA SET for transactions.
# Local single-node replica set:  mongodb://localhost:27017/ecommerce?replicaSet=rs0
# MongoDB Atlas (recommended for Render):  mongodb+srv://USER:PASS@cluster.mongodb.net/ecommerce?retryWrites=true&w=majority
# ─────────────────────────────────────────────────────────────
DATABASE_URL="mongodb://localhost:27017/ecommerce?replicaSet=rs0"

# ─────────────────────────────────────────────────────────────
# NextAuth / JWT (Module 11)
# ─────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
JWT_ACCESS_SECRET="generate-with: openssl rand -base64 32"
JWT_REFRESH_SECRET="generate-with: openssl rand -base64 32"

# ─────────────────────────────────────────────────────────────
# Stripe (test mode) — https://dashboard.stripe.com/test/apikeys
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# ─────────────────────────────────────────────────────────────
# Redis (Module 10) — optional; app falls back to in-memory cache if unset.
# Local: redis://localhost:6379  |  Upstash/Render: rediss://...
# ─────────────────────────────────────────────────────────────
REDIS_URL=""

# ─────────────────────────────────────────────────────────────
# Email (Module 3 NotificationService) — SMTP. Leave blank to log to console.
# ─────────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Noon Commerce <no-reply@example.com>"

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
