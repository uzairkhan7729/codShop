// ───────────────────────────────────────────────────────────────────────────
// Prisma schema — MongoDB
//
// NOTE: MongoDB with Prisma requires a REPLICA SET to support multi-document
// transactions (used by InventoryService.reserveStock / OrderService.createOrder).
// Locally run mongod as a single-node replica set; Atlas works out of the box.
//
// Apply with:  npm run db:push   (MongoDB has no SQL migrations)
// All collections are prefixed with `ecom_` via @@map.
// ───────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum Role {
  CUSTOMER
  ADMIN
}

enum AddressType {
  SHIPPING
  BILLING
}

enum OrderStatus {
  PENDING // created, awaiting payment
  PAID // payment succeeded
  PROCESSING // being prepared
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
}

enum CouponType {
  PERCENTAGE
  FIXED
}

// ───────────────────── Composite (embedded) types ─────────────────────

// Snapshot of an address embedded onto an Order so historical orders are
// immutable even if the user later edits/deletes their saved address.
type OrderAddress {
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String
}

// ─────────────────────────── Models ───────────────────────────

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  password      String // bcrypt hash
  name          String
  phone         String?
  image         String?
  role          Role      @default(CUSTOMER)
  isBlocked     Boolean   @default(false)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses    Address[]
  orders       Order[]
  cart         Cart?
  reviews      Review[]
  wishlist     WishlistItem[]
  sessions     Session[]
  activityLogs ActivityLog[]
  redemptions  CouponRedemption[]

  @@index([createdAt])
  @@map("ecom_users")
}

// Refresh-token / session store (Module 11 — JWT with refresh tokens)
model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  refreshToken String   @unique // hashed refresh token
  userAgent    String?
  ip           String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("ecom_sessions")
}

model Address {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  userId     String      @db.ObjectId
  type       AddressType @default(SHIPPING)
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String      @default("AE")
  isDefault  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ecom_addresses")
}

model Category {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  description String?
  image       String?
  parentId    String?  @db.ObjectId
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Self-relation for nested hierarchy
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId])
  @@map("ecom_categories")
}

model Product {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  slug             String   @unique
  description      String
  price            Float
  comparePrice     Float? // original / "was" price for discount badge
  currency         String   @default("USD")
  sku              String   @unique
  brand            String?
  images           String[] // ordered array of image URLs
  categoryId       String   @db.ObjectId
  stock            Int      @default(0)
  lowStockThreshold Int     @default(5)
  reservedStock    Int      @default(0) // held during checkout, released on cancel
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  ratingAvg        Float    @default(0)
  ratingCount      Int      @default(0)
  soldCount        Int      @default(0)

  // SEO (Module 6 product form)
  metaTitle       String?
  metaDescription String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category   Category         @relation(fields: [categoryId], references: [id])
  variants   ProductVariant[]
  reviews    Review[]
  cartItems  CartItem[]
  orderItems OrderItem[]
  wishlist   WishlistItem[]

  @@index([categoryId])
  @@index([createdAt])
  @@index([isFeatured])
  @@index([price])
  @@map("ecom_products")
}

model ProductVariant {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String   @db.ObjectId
  sku       String   @unique
  size      String? // e.g. "M", "42", "256GB"
  color     String? // e.g. "Midnight Black"
  price     Float? // optional override of the parent product price
  stock     Int      @default(0)
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@map("ecom_product_variants")
}

model Cart {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  couponId  String?  @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon Coupon?    @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items  CartItem[]

  @@map("ecom_carts")
}

model CartItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  cartId    String   @db.ObjectId
  productId String   @db.ObjectId
  variantId String?  @db.ObjectId
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@map("ecom_cart_items")
}

model WishlistItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  productId String   @db.ObjectId
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("ecom_wishlist_items")
}

model Order {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber  String      @unique // human-friendly, e.g. "ORD-2026-0001"
  userId       String      @db.ObjectId
  status       OrderStatus @default(PENDING)

  // Money (all stored in major units, e.g. AED)
  subtotal     Float
  discount     Float       @default(0)
  tax          Float       @default(0)
  shippingCost Float       @default(0)
  total        Float

  couponCode   String?
  shippingMethod String   @default("STANDARD")
  trackingNumber String?
  carrier        String?
  notes          String?
  cancelReason   String?

  shippingAddress OrderAddress
  billingAddress  OrderAddress?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  items   OrderItem[]
  payment Payment?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("ecom_orders")
}

model OrderItem {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String  @db.ObjectId
  productId String  @db.ObjectId
  variantId String? @db.ObjectId

  // Snapshot of product data at purchase time (immutable history)
  name     String
  image    String?
  sku      String
  price    Float
  quantity Int
  total    Float

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("ecom_order_items")
}

model Payment {
  id                    String          @id @default(auto()) @map("_id") @db.ObjectId
  orderId               String          @unique @db.ObjectId
  provider              PaymentProvider @default(STRIPE)
  status                PaymentStatus   @default(PENDING)
  amount                Float
  currency              String          @default("USD")
  refundedAmount        Float           @default(0)
  stripePaymentIntentId String?         @unique
  stripeChargeId        String?
  failureReason         String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("ecom_payments")
}

model Review {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  productId  String   @db.ObjectId
  userId     String   @db.ObjectId
  rating     Int // 1..5
  title      String?
  comment    String?
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId]) // one review per user per product
  @@index([productId])
  @@index([createdAt])
  @@map("ecom_reviews")
}

model Coupon {
  id                String     @id @default(auto()) @map("_id") @db.ObjectId
  code              String     @unique
  description       String?
  type              CouponType @default(PERCENTAGE)
  value             Float // percent (0-100) or fixed amount
  minPurchase       Float      @default(0)
  maxDiscount       Float? // cap for percentage coupons
  usageLimit        Int? // total redemptions allowed (null = unlimited)
  usageLimitPerUser Int        @default(1)
  usedCount         Int        @default(0)
  isActive          Boolean    @default(true)
  startsAt          DateTime   @default(now())
  expiresAt         DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  carts       Cart[]
  redemptions CouponRedemption[]

  @@map("ecom_coupons")
}

model CouponRedemption {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  couponId  String   @db.ObjectId
  userId    String   @db.ObjectId
  orderId   String   @db.ObjectId
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([couponId, userId])
  @@map("ecom_coupon_redemptions")
}

model ActivityLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  action    String // e.g. "ORDER_CREATED", "PRODUCT_UPDATED", "USER_LOGIN"
  entity    String? // e.g. "Order", "Product"
  entityId  String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("ecom_activity_logs")
}
